{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "easy_acc_transaction.schema.json",
  "title": "EASY-ACC Base Transaction Payload",
  "type": "object",
  "required": [
    "schema_version",
    "automation_status",
    "transaction_type",
    "target_module",
    "target_screen_id",
    "evidence_level",
    "source",
    "fields",
    "validation",
    "ui_input_policy"
  ],
  "properties": {
    "schema_version": { "const": "easy_acc_transaction_v1" },
    "payload_id": { "type": "string" },
    "created_at": { "type": "string" },
    "automation_status": {
      "enum": [
        "ready_for_review",
        "ready_for_ui_input",
        "blocked_missing_data",
        "blocked_validation_error",
        "blocked_duplicate_risk",
        "blocked_unsupported_case"
      ]
    },
    "transaction_type": {
      "enum": [
        "sale_invoice", "service_sale", "online_sale", "customer_deposit",
        "sale_credit_note", "sale_debit_note",
        "ar_sale_receivable",
        "ap_expense", "ap_purchase_invoice", "ap_expense_with_wht",
        "ap_expense_with_retention", "mixed_vat_purchase", "late_input_vat",
        "gl_journal", "human_review_required"
      ]
    },
    "target_module": { "enum": ["AR", "AP", "GL", "BI"] },
    "target_screen_id": {
      "enum": [
        "UI-AR-TRANSACTION-ENTRY-v1",
        "UI-AP-TRANSACTION-ENTRY-v1",
        "UI-GL-TRANSACTION-ENTRY-v1",
        "UI-BI-BILLING-ENTRY-v1",
        "UNKNOWN"
      ]
    },
    "evidence_level": { "enum": ["verified_ui", "verified_source", "configured_map", "inferred"] },
    "required_human_confirmation": { "type": "boolean" },
    "company_guard": {
      "type": "object",
      "properties": {
        "expected_company_name": { "type": "string" },
        "expected_path_contains": { "type": "string" },
        "expected_period_be_year": { "type": "integer" }
      }
    },
    "source": {
      "type": "object",
      "required": ["source_type"],
      "properties": {
        "source_type": { "enum": ["manual_text", "ocr", "pdf", "image", "excel", "email"] },
        "source_reference": { "type": "string" },
        "source_confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "fields": { "type": "object" },
    "calculations": { "type": "object" },
    "validation": {
      "type": "object",
      "required": ["passed"],
      "properties": {
        "passed": { "type": "boolean" },
        "checks": { "type": "array" },
        "warnings": { "type": "array" },
        "errors": { "type": "array" }
      }
    },
    "duplicate_check": {
      "type": "object",
      "properties": {
        "risk_level": { "enum": ["unknown", "low", "medium", "high"] },
        "keys": { "type": "array" }
      }
    },
    "ui_input_policy": {
      "type": "object",
      "required": ["allow_prepare", "allow_input", "allow_save"],
      "properties": {
        "allow_prepare": { "type": "boolean" },
        "allow_input": { "type": "boolean" },
        "allow_save": { "type": "boolean" },
        "requires_human_confirmation": { "type": "boolean" },
        "mode": {
          "enum": [
            "dry_run",
            "supervised_input_no_save",
            "supervised_input_with_save",
            "production_input_with_save"
          ]
        }
      }
    }
  }
}
