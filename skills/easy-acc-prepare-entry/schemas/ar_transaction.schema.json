{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ar_transaction.schema.json",
  "title": "EASY-ACC AR Transaction Fields",
  "allOf": [{ "$ref": "easy_acc_transaction.schema.json" }],
  "properties": {
    "target_module": { "const": "AR" },
    "target_screen_id": { "const": "UI-AR-TRANSACTION-ENTRY-v1" },
    "fields": {
      "type": "object",
      "required": ["transaction_radio", "document_date", "customer_code", "account_code", "amount_before_vat"],
      "properties": {
        "transaction_radio": { "enum": ["ลูกหนี้", "เงินสด", "เช็ค", "บัตรเครดิต", "อื่นๆ"] },
        "document_date": { "type": "string" },
        "tax_invoice_no": { "type": "string" },
        "customer_code": { "type": "string" },
        "account_code": { "type": "string" },
        "amount_before_vat": { "type": "number" },
        "discount": { "type": "number" },
        "output_vat": { "type": "number" },
        "due_date": { "type": "string" },
        "salesperson_code": { "type": "string" },
        "note": { "type": "string" }
      }
    }
  }
}
